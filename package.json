  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "command-line-args": "^6.0.2",
    "command-line-usage": "^7.0.4",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
