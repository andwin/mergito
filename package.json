{
  "name": "mergito",
  "version": "0.0.1",
  "description": "CLI tool for merging Git branches",
  "bin": {
    "mergito": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "dev": "tsc -w",
    "test": "tsc --noEmit && biome check .",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [],
